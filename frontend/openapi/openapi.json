  "components": {
    "schemas": {
      "AnalysisReport": {
        "properties": {
          "stock_code": {
            "type": "string",
            "title": "Stock Code",
            "description": "股票代码"
          },
          "stock_name": {
            "type": "string",
            "title": "Stock Name",
            "description": "股票名称"
          },
          "report_date": {
            "type": "string",
            "title": "Report Date",
            "description": "报告日期"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Generated At",
            "description": "生成时间"
          },
          "executive_summary": {
            "type": "string",
            "title": "Executive Summary",
            "description": "执行摘要 / Executive Summary"
          },
          "profitability_analysis": {
            "type": "string",
            "title": "Profitability Analysis",
            "description": "盈利能力分析"
          },
          "solvency_analysis": {
            "type": "string",
            "title": "Solvency Analysis",
            "description": "偿债能力分析"
          },
          "efficiency_analysis": {
            "type": "string",
            "title": "Efficiency Analysis",
            "description": "运营效率分析"
          },
          "cashflow_analysis": {
            "type": "string",
            "title": "Cashflow Analysis",
            "description": "现金流分析"
          },
          "trend_analysis": {
            "type": "string",
            "title": "Trend Analysis",
            "description": "趋势分析"
          },
          "strengths": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Strengths",
            "description": "优势 / Strengths"
          },
          "weaknesses": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Weaknesses",
            "description": "劣势 / Weaknesses"
          },
          "recommendations": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Recommendations",
            "description": "建议 / Recommendations"
          },
          "risk_warnings": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Risk Warnings",
            "description": "风险提示 / Risk Warnings"
          }
        },
        "type": "object",
        "required": [
          "stock_code",
          "stock_name",
          "report_date",
          "executive_summary",
          "profitability_analysis",
          "solvency_analysis",
          "efficiency_analysis",
          "cashflow_analysis",
          "trend_analysis"
        ],
        "title": "AnalysisReport",
        "description": "AI 生成的综合分析报告 / AI-Generated Analysis Report",
        "example": {
          "executive_summary": "该公司财务状况良好...",
          "recommendations": [
            "关注市场份额变化"
          ],
          "report_date": "2023-12-31",
          "stock_code": "600519",
          "stock_name": "贵州茅台",
          "strengths": [
            "盈利能力强",
            "现金流充沛"
          ],
          "weaknesses": [
            "资产周转率偏低"
          ]
        }
      },
      "CashFlowResult": {
        "properties": {
          "operating_cashflow": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Operating Cashflow",
            "description": "经营活动现金流量净额"
          },
          "free_cash_flow": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Free Cash Flow",
            "description": "自由现金流 / Free Cash Flow"
          },
          "cash_to_profit_ratio": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Cash To Profit Ratio",
            "description": "现金流量与净利润比率"
          },
          "operating_cash_coverage": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Operating Cash Coverage",
            "description": "经营现金流覆盖率"
          }
        },
        "type": "object",
        "required": [
          "operating_cashflow",
          "free_cash_flow",
          "cash_to_profit_ratio",
          "operating_cash_coverage"
        ],
        "title": "CashFlowResult",
        "description": "现金流分析结果 / Cash Flow Analysis Result"
      },
      "CrawlJobRequest": {
        "properties": {
          "stock_code": {
            "type": "string",
            "title": "Stock Code",
            "description": "Target stock code"
          }
        },
        "type": "object",
        "required": [
          "stock_code"
        ],
        "title": "CrawlJobRequest"
      },
      "CrawlJobResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "stock_code": {
            "type": "string",
            "title": "Stock Code"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "stock_code",
          "status",
          "created_at"
        ],
        "title": "CrawlJobResponse"
      },
      "DuPontResult": {
        "properties": {
          "roe": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Roe",
            "description": "净资产收益率 / ROE"
          },
          "net_profit_margin": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Net Profit Margin",
            "description": "销售净利率 / Net Profit Margin"
          },
          "asset_turnover": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Asset Turnover",
            "description": "总资产周转率 / Asset Turnover"
          },
          "equity_multiplier": {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Equity Multiplier",
            "description": "权益乘数 / Equity Multiplier"
          }
        },
        "type": "object",
        "required": [
          "roe",
          "net_profit_margin",
          "asset_turnover",
          "equity_multiplier"
        ],
        "title": "DuPontResult",
        "description": "杜邦分析结果 / DuPont Analysis Result\n\nROE = 销售净利率 × 总资产周转率 × 权益乘数",
        "example": {
          "asset_turnover": "0.5000",
          "equity_multiplier": "1.0000",
          "net_profit_margin": "0.3000",
          "roe": "0.1500"
        }
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "StockInfo": {
        "properties": {
          "stock_code": {
            "type": "string",
            "title": "Stock Code",
            "description": "股票代码 / Stock Code"
          },
          "stock_name": {
            "type": "string",
            "title": "Stock Name",
            "description": "股票名称 / Stock Name"
          },
          "industry": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Industry",
            "description": "所属行业 / Industry"
          },
          "market": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Market",
            "description": "市场类型 / Market (主板/创业板/科创板)"
          },
          "list_date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "List Date",
            "description": "上市日期 / Listing Date"
          }
        },
        "type": "object",
        "required": [
          "stock_code",
          "stock_name"
        ],
        "title": "StockInfo",
        "description": "股票基础信息模型",
        "example": {
          "industry": "白酒",
          "list_date": "2001-08-27",
          "market": "主板",
          "stock_code": "600519",
          "stock_name": "贵州茅台"
        }
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
